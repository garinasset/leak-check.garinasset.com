# ============================================================================
# 本地开发环境变量示例
# ============================================================================
# 
# 说明：
#   1. 复制此文件内容到 .env.local
#   2. 本地开发时按需修改下面的值
#   3. .env.local 不要提交到 Git
#   4. 生产环境请改 PM2 的 ecosystem.config.js
# ============================================================================

# 🔐 客户端混淆配置
# ============================================================================
# 用于客户端混淆、服务端还原的 key
# 注意：NEXT_PUBLIC_ 前缀表示这个值会暴露到客户端代码
# 这不是服务器秘密，只是请求体混淆协议的一部分
# 
NEXT_PUBLIC_OBFUSCATION_KEY=dev-secret-key-12345

# 🌐 后端 API 地址
# ============================================================================
PERSON_BACKEND_URL=http://172.16.1.4/leak-check/dig/masking

PERSON_COUNT_URL=http://172.16.1.4/leak-check/
